# Managed by Ansible — do not edit manually
# Role: flaskapp

{{ flaskapp_root }}/logs/*.log {
    daily
    rotate {{ flaskapp_log_rotate_days }}
    compress
    delaycompress
    missingok
    notifempty
    create 0640 {{ flaskapp_user }} {{ flaskapp_group }}
    sharedscripts
    postrotate
        systemctl reload {{ flaskapp_name }} > /dev/null 2>&1 || true
    endscript
}
