serverName = '{{ managed_server }}'

print('[WLST] Connecting to Admin Server: ' + adminUrl)
try:
    connect(adminUser, adminPass, adminUrl)
except Exception as e:
    print('[WLST] ERROR connecting to Admin Server: ' + str(e))
    sys.exit(1)

print('[WLST] Checking state of ' + serverName)
try:
    domainRuntime()
    cd('ServerLifeCycleRuntimes/' + serverName)
    state = cmo.getState()
    print('[WLST] Current state: ' + state)

    if state not in ['SHUTDOWN', 'FAILED']:
        print('[WLST] Shutting down ' + serverName + ' ...')
        shutdown(serverName, 'Server', ignoreSessions=True, timeOut=300, force=False)
        print('[WLST] ' + serverName + ' shutdown complete.')
    else:
        print('[WLST] ' + serverName + ' already in state: ' + state + '. No action needed.')

except Exception as e:
    print('[WLST] ERROR during shutdown: ' + str(e))
    disconnect()
    sys.exit(1)

disconnect()
