{
  "agent": {
    "metrics_collection_interval": 60,
    "run_as_user": "root"
  },
  "logs": {
    "logs_collected": {
      "files": {
        "collect_list": [
          {
            "file_path": "/var/log/audit-enriched/audit-enriched.json",
            "log_group_name": "/aws/ec2/audit/{{ ec2_account_id }}",
            "log_stream_name": "{{ ec2_instance_id }}",
            "timezone": "UTC",
            "multi_line_start_pattern": "^\\{",
            "timestamp_format": "%Y-%m-%dT%H:%M:%S",
            "retention_in_days": 90
          },
          {
            "file_path": "{{ auditd_log_file }}",
            "log_group_name": "/aws/ec2/audit-raw/{{ ec2_account_id }}",
            "log_stream_name": "{{ ec2_instance_id }}",
            "timezone": "UTC",
            "retention_in_days": 30
          }
        ]
      }
    },
    "log_stream_name": "{{ ec2_instance_id }}",
    "force_flush_interval": 15
  }
}
